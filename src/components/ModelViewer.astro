---
// ModelViewer.astro
// Placeholder component for 3D .glb models (Luma AI or similar)
// Includes accessibility and AR flags out of the box.

interface Props {
    src: string;
    alt: string;
    autoRotate?: boolean;
    cameraControls?: boolean;
    ar?: boolean;
}

const {
    src,
    alt,
    autoRotate = true,
    cameraControls = true,
    ar = true,
} = Astro.props;
---

<div
    class="model-viewer-container relative w-full h-[400px] bg-white/5 rounded-2xl overflow-hidden border border-white/10 shadow-lg"
    aria-label={`3D Model: ${alt}`}
>
    <!-- 
    The script must be loaded as a module for model-viewer to work.
    Using 'is:inline' ensures Astro doesn't bundle it incorrectly and loads it as needed.
  -->
    <script
        type="module"
        src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"
        is:inline></script>

    <model-viewer
        src={src}
        alt={alt}
        auto-rotate={autoRotate ? "true" : undefined}
        camera-controls={cameraControls ? "true" : undefined}
        ar={ar ? "true" : undefined}
        shadow-intensity="1"
        exposure="1"
        environment-image="neutral"
        class="w-full h-full"
    >
        <div
            slot="progress-bar"
            class="w-full h-1 bg-white/20 absolute top-0 left-0"
        >
            <div
                class="update-bar bg-(--color-primary) h-full w-0 transition-all duration-300"
            >
            </div>
        </div>
    </model-viewer>
</div>

<style>
    model-viewer {
        width: 100%;
        height: 100%;
        background-color: transparent;
        --poster-color: transparent;
    }
</style>
