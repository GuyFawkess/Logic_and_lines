---
// Stats.astro
const { currentLang = "es" } = Astro.props;
import { useTranslations } from "../i18n/utils";
const t = useTranslations(currentLang);
---

<!-- bg-gradient-to-b from-[#0a1f1f] to-[#0f2f2f] -->
<section class="w-full pt-12 bg-(--color-bg-alt)">
  <div class="max-w-7xl mx-auto px-4 mb-8 mt-16">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2
        class="text-4xl md:text-5xl font-bold mb-4"
        set:html={t.stats.title}
      />
      <p class="text-(--color-text) text-lg md:text-xl max-w-2xl mx-auto">
        {t.stats.subtitle}
      </p>
    </div>

    <div
      data-duration="700"
      data-animate="fade-up"
      class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12"
    >
      {
        t.stats.items.map((stat) => (
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-[#F59E0B] mb-3">
              {stat.value}
            </div>
            <div class="text-(--color-text) text-xl font-bold mb-1">
              {stat.label}
            </div>
            <div class="text-(--color-text-dark) text-lg">{stat.subLabel}</div>
          </div>
        ))
      }
    </div>
  </div>

  <svg
    data-name="Layer 1"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 1200 120"
    preserveAspectRatio="none"
    class="w-full h-auto -bottom-px block relative z-10 -mb-10"
  >
    <path
      d="M1200,0 C800,50 400,60 0,0 L0,120 L1200,120 Z"
      class="shape-fill"
      fill="var(--color-bg)"
      fill-opacity="1"></path>
  </svg>
</section>
